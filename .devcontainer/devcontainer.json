{
    "name": "Deply DevContainer",
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-docker",
                "tamasfe.even-better-toml",
                "eamodio.gitlens",
                "GitHub.copilot",
                "github.vscode-github-actions"
            ]
        }
    },
    "containerEnv": {
        "APP_NAME": "DEPLY",
        "DEPLY_ENV": "development"
    },
    "postCreateCommand": "uv sync --all-extras",
    "remoteUser": "vscode"
}
